# =============================================================================
# Aichestr — Environment variables
# =============================================================================
# Copy this file to .env.local (Next.js) or .env (for the API server).
# Next.js: .env.local is loaded automatically and not committed.
# API server: Bun loads .env from project root when running `bun run server`.
# =============================================================================

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------

# Google AI (Gemini) API key. Get one at https://aistudio.google.com
# Used by the Fastify API server for task analysis (server/gemini/client.ts).
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Optional — API server (Fastify)
# -----------------------------------------------------------------------------

# Port for the Fastify API server. Default: 3001
API_PORT=3001

# SQLite database file path.
# Default: system temp dir (e.g. /tmp/aichestr-tasks.db) to avoid iCloud issues.
# On macOS: avoid paths under ~/Documents or ~/Desktop (iCloud Drive) to prevent
# SQLITE_IOERR_VNODE. Use /tmp or another non-synced path for local dev.
# DB_PATH=/tmp/aichestr-tasks.db

# -----------------------------------------------------------------------------
# Optional — Next.js frontend
# -----------------------------------------------------------------------------

# Base URL for the API. Must be NEXT_PUBLIC_ so the client can read it.
# Default: http://localhost:3001/api
# Set this when the API is hosted elsewhere (e.g. production).
# NEXT_PUBLIC_API_URL=http://localhost:3001/api
